# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# モジュールファイル
*.gcm
*.pcm

# 出力ファイル
BeMighty/
x64/

# .vsは不要
.vs/


# slangの出力ファイル
*.spv

# geanyプロジェクトファイル
*.geany

# outフォルダの中身を無視
out/*

# 一旦vulkanを無視
/libraries/vulkan/**

# 外部コンテンツのディレクトリ構造のみ管理
# https://zenn.dev/purigen/articles/67bb8de047e1bb#%E3%83%87%E3%82%A3%E3%83%AC%E3%82%AF%E3%83%88%E3%83%AA%E6%A7%8B%E9%80%A0%E3%81%AE%E3%81%BF%E7%AE%A1%E7%90%86%E3%81%97%E3%81%9F%E3%81%84
/thirdparties/**
!/thirdparties/**/

# リンクはいつでも含める
!*.url
!*.desktop

# 外部ライセンスはいつでも含める
!LICENSE.*
!copying.txt
!copyright

# フォルダは無視しない
!.gitkeep
